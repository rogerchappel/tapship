{
  "name": "tapship",
  "version": "0.1.0",
  "description": "Local-first CLI for drafting Homebrew formulae, casks, and release docs from release metadata.",
  "type": "module",
  "bin": {
    "tapship": "./bin/tapship.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "README.md"
  ],
  "scripts": {
    "check": "node scripts/check.js",
    "test": "node --test",
    "build": "node scripts/build.js",
    "smoke": "node scripts/smoke.js"
  },
  "keywords": [
    "homebrew",
    "cli",
    "release",
    "brew",
    "cask"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
