{
  "name": "tapship-mvp",
  "entry": "bin/tapship.js",
  "defaultCommand": "plan",
  "steps": [
    { "id": "read-input", "description": "Load local release metadata fixture" },
    { "id": "normalize", "description": "Normalize release and brew metadata" },
    { "id": "classify", "description": "Find formula and cask candidate assets" },
    { "id": "validate", "description": "Check checksums, URLs, and naming rules" },
    { "id": "render", "description": "Generate formula, cask, install, and checklist outputs" },
    { "id": "write", "description": "Persist outputs only when --write is passed" }
  ],
  "safety": {
    "network": false,
    "publish": false,
    "defaultWrite": false
  }
}
